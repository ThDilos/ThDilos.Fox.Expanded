												{
													"type": "origins:if_else",
													"condition": {
														"type": "origins:origin",
														"layer": "thorigins:origin",
														"origin": "thorigins:kitsune"
													},
													"if_action": {
														"type": "origins:execute_command",
														"command": "/item modify entity @s weapon.mainhand thorigins:kitsune_bless"
													},
													"else_action": {
														"type": "origins:execute_command",
														"command": "/item modify entity @s weapon.mainhand thorigins:ninetails_curse"
													}
												},
												{
													"type": "origins:play_sound",
													"sound": "minecraft:block.enchantment_table.use",
													"category": "players"
												},
												{
													"type": "origins:spawn_particles",
													"particle": "minecraft:enchant",
													"count": 30,
													"spread": {
														"x": 0.3,
														"y": 0.2,
														"z": 0.3
													}
												},
												{
													"type": "origins:spawn_particles",
													"particle": "minecraft:glow",
													"count": 20,
													"spread": {
														"x": 0.25,
														"y": 0.35,
														"z": 0.25
													},
													"offset_y": 0.275
												}
											]
										},
										"else_action": {
											"type": "origins:and",
											"actions": [
												{
													"type": "origins:execute_command",
													"command": "/title @s actionbar {\"translate\":\"thstorage2.enchant.not_enough_lvl\",\"fallback\":\"Enhancing this item requires [%s] Levels!\",\"with\":[{\"score\":{\"name\":\"*\",\"objective\":\"thorigins.selected_item_lvl\"},\"color\":\"red\"}],\"color\":\"yellow\"}"
												},
												{
													"type": "origins:execute_command",
													"command": "/playsound minecraft:entity.wolf.whine player @s ~ ~ ~ 0.2 1.5"
												},
												{
													"type": "origins:execute_command",
													"command": "/scoreboard players reset @s thorigins.selected_item_lvl"
												}
											]
										}
									}
								]
