										},
										{
											"type": "origins:execute_command",
											"command": "/data modify entity @e[tag=to_be_modified,limit=1,sort=nearest] Item set from entity @s SelectedItem"
										},
										{
											"type": "origins:equipped_item_action",
											"equipment_slot": "mainhand",
											"action": {
												"type": "origins:consume"
