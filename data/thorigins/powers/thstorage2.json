												"x": 0.25,
												"y": 0.35,
												"z": 0.25
											},
											"offset_y": 0.275
										}
									]
								},
								"else_action": {
									"type": "origins:and",
									"actions": [
										{
											"type": "origins:execute_command",
											"command": "/title @s actionbar {\"translate\":\"thstorage2.enchant.not_enough_lvl\",\"fallback\":\"Enhancing this item requires [%s] Levels!\",\"with\":[{\"score\":{\"name\":\"*\",\"objective\":\"thorigins.enhance_level_req_talisman\"},\"color\":\"red\"}],\"color\":\"yellow\"}"
										},
										{
											"type": "origins:execute_command",
											"command": "/playsound minecraft:entity.wolf.whine player @s ~ ~ ~ 0.2 1.5"
										}
									]
								}
							}
						},
						{
							"condition": {
								"type": "origins:constant",
								"value": true
