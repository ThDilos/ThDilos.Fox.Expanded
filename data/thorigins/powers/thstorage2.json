							"action": {
								"type": "origins:and",
								"actions": [
									{
										"type": "origins:change_resource",
										"resource": "*:*_get_xp_level_requirement",
										"change": 1
									},
									{
										"type": "origins:if_else",
										"condition": {
											"type": "origins:command",
											"command": "/execute if score @s thorigins.selected_item_lvl <= @s thorigins.player.xp_lvl",
											"compare_to": 0,
											"comparison": ">"
										},
