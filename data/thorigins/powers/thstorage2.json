{
	"type": "origins:multiple",
	"name": "thstorage2.name",
	"description": "thstorage2.description",

	"init": {
		"type": "origins:action_on_callback",
		"entity_action_added": {
			"type": "origins:and",
			"actions": [
				{
					"type": "origins:execute_command",
					"command": "/scoreboard objectives add thorigins.selected_item_lvl dummy"
				},
				{
					"type": "origins:execute_command",
					"command": "/scoreboard objectives add thorigins.player.xp_lvl level"
				},
				{
					"type": "origins:execute_command",
					"command": "/scoreboard objectives add thorigins.enhance_level_req_per_stack dummy"
				},
				{
					"type": "origins:execute_command",
					"command": "/scoreboard players add thorigins.player.xp_lvl 0"
				},
				{
					"type": "origins:execute_command",
					"command": "/scoreboard players set @s thorigins.enhance_level_req_per_stack 8"
				},
				{
					"type": "origins:execute_command",
					"command": "/scoreboard objectives add thorigins.enhance_level_req_talisman dummy"
				},
				{
					"type": "origins:execute_command",
					"command": "/scoreboard players set @s thorigins.enhance_level_req_talisman 20"
				}
			]
		}
	},

	"ticks_20": {
		"type": "origins:action_over_time",
		"entity_action": {
			"type": "origins:if_else",
			"condition": {
				"type": "origins:and",
				"conditions": [
					{
						"type": "origins:inventory",
						"power": "*:*_tails",
						"inventory_types": ["power"],
						"process_mode": "stacks",
						"slots": [
							"container.0",
							"container.2",
							"container.6",
							"container.8"
						],
						"compare_to": 3,
						"comparison": ">",
						"item_condition": {
							"type": "origins:ingredient",
							"ingredient": {
								"item": "minecraft:amethyst_shard"
							}
						}
					},
					{
						"type": "origins:inventory",
						"power": "*:*_tails",
						"inventory_types": ["power"],
						"process_mode": "stacks",
						"slots": [
							"container.1",
							"container.3",
							"container.5",
							"container.7"
						],
						"compare_to": 3,
						"comparison": ">",
						"item_condition": {
							"type": "origins:ingredient",
							"ingredient": {
								"item": "minecraft:lapis_lazuli"
							}
						}
					},
					{
						"type": "origins:inventory",
						"power": "*:*_tails",
						"inventory_types": ["power"],
						"process_mode": "stacks",
						"slot": "container.4",
						"compare_to": 0,
						"comparison": ">",
						"item_condition": {
							"type": "origins:ingredient",
							"ingredient": {
								"item": "minecraft:nether_star"
							}
						}
					}
				]
			},
			"if_action": {
				"type": "origins:change_resource",
				"resource": "*:*_allowed_to_enhance",
				"change": 1
			},
			"else_action": {
				"type": "origins:change_resource",
				"resource": "*:*_allowed_to_enhance",
				"change": -1
			}
		}
	},

	"selected_item_lvl": {
		"type": "origins:resource",
		"min": 0,
		"max": 255
	},

	"get_xp_level_requirement": {
		"type": "origins:resource",
		"min": 0,
		"max": 1,
		"start_value": 0,
		"max_action": {
			"type": "origins:and",
			"actions": [
				{
					"type": "origins:change_resource",
					"resource": "*:*_get_xp_level_requirement",
					"change": -1
				},
				{
					"type": "origins:if_else",
					"condition": {
						"type": "origins:origin",
						"layer": "thorigins:origin",
						"origin": "thorigins:kitsune"
					},
					"if_action": {
						"type": "origins:execute_command",
						"command": "/execute store result score @s thorigins.selected_item_lvl run data get entity @s SelectedItem.tag.Enchantments[{id:\"minecraft:smite\"}].lvl"
					},
					"else_action": {
						"type": "origins:execute_command",
						"command": "/execute store result score @s thorigins.selected_item_lvl run data get entity @s SelectedItem.tag.Enchantments[{id:\"minecraft:sharpness\"}].lvl"
					}
				},
				{
					"type": "origins:execute_command",
					"command": "/scoreboard players add @s thorigins.selected_item_lvl 1"
				},
				{
					"type": "origins:execute_command",
					"command": "/resource operation @s thorigins:thstorage2_selected_item_lvl = @s thorigins.selected_item_lvl"
				},
				{
					"type": "origins:execute_command",
					"command": "/scoreboard players operation @s thorigins.selected_item_lvl *= @s thorigins.enhance_level_req_per_stack"
				}
			]
		}
	},

	"extract_xp": {
		"type": "origins:resource",
		"min": 0,
		"max": 1,
		"max_action": {
			"type": "origins:and",
			"actions": [
				{
					"type": "origins:change_resource",
					"resource": "*:*_extract_xp",
					"change": -1
				},
				{
					"type": "origins:change_resource",
					"resource": "*:*_selected_item_lvl",
					"change": -1
				},
				{
					"type": "origins:add_xp",
					"levels": -8
				},
				{
					"type": "origins:if_else",
					"condition": {
						"type": "origins:resource",
						"resource": "*:*_selected_item_lvl",
						"compare_to": 0,
						"comparison": ">"
					},
					"if_action": {
						"type": "origins:change_resource",
						"resource": "*:*_extract_xp",
						"change": 1
					}
				}
			]
		}
	},

	"enhance": {
		"type": "origins:resource",
		"min": 0,
		"max": 1,
		"max_action": {
			"type": "origins:and",
			"actions": [
				{
					"type": "origins:change_resource",
					"resource": "*:*_enhance",
					"change": -1
				},
				{
					"type": "origins:if_else_list",
