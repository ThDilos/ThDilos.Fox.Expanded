{
	"type": "origins:multiple",
	"hidden": true,

	"ticks": {
		"type": "origins:action_over_time",
		"entity_action": {
			"type": "origins:revoke_power",
			"power": "*:ninetails/soul_imprint",
			"source": "thorigins:temp"
		},
		"condition": {
			"type": "origins:resource",
			"resource": "*:*_timer",
			"compare_to": 0,
			"comparison": "=="
		}
	},

	"init": {
		"type": "origins:action_on_callback",
		"entity_action_gained": {
			"type": "origins:execute_command",
			"command": "/title @s actionbar {\"translate\":\"thorigins.ninetails_talisman.ability0.hint\",\"fallback\":\"You are marked! All Healings are disabled for the next 10s.\"}"
		},
		"entity_action_lost": {
			"type": "origins:execute_command",
			"command": "/scoreboard players reset @s thorigins.ninetails.ninetails_talisman.imprinted_by_uuid0"
		}
	},

	"timer": {
		"type": "origins:cooldown",
		"cooldown": 200,
		"hud_render": {
			"should_render": true,
			"inverted": true,
			"sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_03.png",
			"bar_index": 4
		}
	},

	"disabled_healing": {
		"type": "origins:modify_healing",
		"modifier": {
			"operation": "set_total",
			"value": 0
		}
	}
}
